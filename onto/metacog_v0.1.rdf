    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#DetectionRange -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#DetectionRange">
