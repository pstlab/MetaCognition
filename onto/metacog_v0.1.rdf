    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ConsumptionCapability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ConsumptionCapability">
