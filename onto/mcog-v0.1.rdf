    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ConsumptionCapability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ConsumptionCapability">
