                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#hasCapability"/>
                                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#NavigationCapability"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
