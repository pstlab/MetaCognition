<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/anacleto/ontologies/2025/9/untitled-ontology-10/"
     xml:base="http://www.semanticweb.org/anacleto/ontologies/2025/9/untitled-ontology-10/"
     xmlns:DUL="http://www.loa-cnr.it/ontologies/DUL.owl#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#">
    <owl:Ontology rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog">
        <owl:versionIRI rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog/1.0.0"/>
        <owl:imports rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho/1.0.0"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning -->

    <owl:ObjectProperty rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning">
        <rdfs:subPropertyOf rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#requires"/>
        <rdfs:domain rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#ProductionMethod"/>
        <rdfs:range rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ReasoningMethod"/>
    </owl:ObjectProperty>
    


    <!-- http://www.loa-cnr.it/ontologies/DUL.owl#hasPart -->

    <owl:ObjectProperty rdf:about="http://www.loa-cnr.it/ontologies/DUL.owl#hasPart">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.loa-cnr.it/ontologies/DUL.owl#isPartOf -->

    <owl:ObjectProperty rdf:about="http://www.loa-cnr.it/ontologies/DUL.owl#isPartOf">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://pst.istc.cnr.it/ontologies/2019/01/soho#Cobot -->

    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Cobot">
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#EmbodiedAgent"/>
    </rdf:Description>
    


    <!-- http://pst.istc.cnr.it/ontologies/2019/01/soho#Function -->

    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Function">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning"/>
                <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#PlanningMethod"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </rdf:Description>
    


    <!-- http://pst.istc.cnr.it/ontologies/2019/01/soho#PickObject -->

    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#PickObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Collect"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning"/>
                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ClassicalPlanning"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#canBePerformedBy"/>
                        <owl:allValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#RobotEmbodiment"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#hasCapability"/>
                                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ObjectLifting"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#hasTarget"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#PhysicalObject"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </rdf:Description>
    


    <!-- http://pst.istc.cnr.it/ontologies/2019/01/soho#PlaceObject -->

    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#PlaceObject">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Release"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning"/>
                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ClassicalPlanning"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#canBePerformedBy"/>
                        <owl:allValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#RobotEmbodiment"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#hasCapability"/>
                                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ObjectLifting"/>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#hasTarget"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#PhysicalObject"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#requires"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#EnvironmentLocation"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </rdf:Description>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#AutonomousNavigation -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#AutonomousNavigation">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#NavigationCapability"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#hasRegion"/>
                        <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                        <owl:onClass rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#Velocity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#NavigationCapability"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#Capability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#Capability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.loa-cnr.it/ontologies/DUL.owl#Quality"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#hasRegion"/>
                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#Capacity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#Quality"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ClassicalPlanning -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ClassicalPlanning">
