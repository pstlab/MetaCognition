    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ObjectContainmentCapability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ObjectContainmentCapability">
