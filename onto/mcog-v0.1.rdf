    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ContainmentCapacity -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ContainmentCapacity">
