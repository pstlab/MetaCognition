    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#Capability"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#hasRegion"/>
                        <owl:allValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapacity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#Capability"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapacity -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapacity">
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#Capacity"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#MoveTo -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#MoveTo">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Channel"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#requiresPlanning"/>
                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ClassicalPlanning"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2019/01/soho#canBePerformedBy"/>
                        <owl:allValuesFrom>
