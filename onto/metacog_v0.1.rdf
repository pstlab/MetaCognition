    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#MoveTo -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#MoveTo">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2019/01/soho#Channel"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#requiresPlanning"/>
                        <owl:someValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ClassicalPlanning"/>
                    </owl:Restriction>
