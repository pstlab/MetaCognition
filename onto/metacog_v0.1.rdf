    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#InteractionCapability -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#InteractionCapability">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#Capability"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.loa-cnr.it/ontologies/DUL.owl#hasRegion"/>
                        <owl:allValuesFrom rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#InteractionCapacity"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#Capability"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#InteractionCapacity -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#InteractionCapacity">
