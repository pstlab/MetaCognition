    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ContingentPlanning -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#ContingentPlanning">
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#PlanningMethod"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#DetectionAccuracy -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#DetectionAccuracy">
        <rdfs:subClassOf rdf:resource="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#InteractionCapacity"/>
    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#DetectionClass -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/mcog#DetectionClass">
