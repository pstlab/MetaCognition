    </owl:Class>
    


    <!-- http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ContainmentCapacity -->

    <owl:Class rdf:about="http://pst.istc.cnr.it/ontologies/2025/dfki/metacog#ContainmentCapacity">
